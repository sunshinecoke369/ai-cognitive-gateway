# AI Cognitive Gateway - Environment Variables
# Copy this file to .env and fill in your values

# ===== Local Model =====
# Mode: "mock" (no local model) or "ollama" (real local model)
LOCAL_MODEL_MODE=mock
OLLAMA_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=qwen2.5:3b
LOCAL_MODEL_CONFIDENCE_THRESHOLD=0.6
REQUEST_TIMEOUT_SEC=10

# ===== Cloud Model =====
# Provider: openai-compatible (DeepSeek, Alibaba, OpenAI) or ollama
DEFAULT_CLOUD_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# DeepSeek:  https://api.deepseek.com/v1         模型: deepseek-chat / deepseek-reasoner
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1  模型: qwen-plus / qwen-max
# OpenAI:    https://api.openai.com/v1             模型: gpt-4o-mini / gpt-4o

# ===== Allowed Models =====
ALLOWED_MODELS_PATH=data/allowed_models.json

# ===== Runtime Config =====
CONFIG_FILE_PATH=data/gateway_config.yaml

# ===== Governance =====
GOVERNANCE_MODE=keyword

# ===== Database & Audit =====
DATABASE_PATH=data/gateway.db
AUDIT_LOG_PATH=logs/audit.jsonl

# ===== Server =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FILE=logs/gateway.log
